# Wicked AI Observatory — environment template
#
# Copy this file to .env and fill in your own values.
# The .env file is excluded from git via .gitignore and must never be committed.

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DB=wao

# --- Anthropic API ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Zotero ---
# Create a group at https://www.zotero.org/groups/
# API key: https://www.zotero.org/settings/keys
ZOTERO_GROUP_ID=your-group-id
ZOTERO_API_KEY=your-zotero-api-key
